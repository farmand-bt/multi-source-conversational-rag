# .streamlit/secrets.toml — Streamlit Cloud secrets template
#
# On Streamlit Community Cloud:
#   Go to your app → ⋮ → Settings → Secrets
#   Paste the content below (with real values) into the secrets editor.
#   Do NOT commit secrets.toml itself — it is in .gitignore.
#
# For local development use .env instead (see .env.example).

GWDG_API_KEY = "your-api-key-here"
GWDG_API_BASE = "https://chat-ai.academiccloud.de/v1"
GWDG_MODEL_NAME = "meta-llama-3.1-70b-instruct"
