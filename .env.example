GWDG_API_KEY=your-api-key-here
GWDG_API_BASE=https://chat-ai.academiccloud.de/v1
GWDG_MODEL_NAME=meta-llama-3.1-70b-instruct

# Optional: HuggingFace token — only needed for gated models.
# The embedding (all-MiniLM-L6-v2) and re-ranking (ms-marco-MiniLM-L-6-v2) models
# used in this project are public, so this can be left empty.
# HF_TOKEN=your-hf-token-here

# Silence the HuggingFace symlinks warning on Windows (cosmetic only, no functionality impact)
HF_HUB_DISABLE_SYMLINKS_WARNING=1
